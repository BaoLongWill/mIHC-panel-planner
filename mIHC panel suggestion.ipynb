import itertools
import pandas as pd

# =========================
# CHANNEL CONFIG
# =========================
CHANNELS = [480, 520, 540, 570, 620, 650, 690, 780]

PREFERRED = [520, 570, 620, 690]
INTERMEDIATE = [540, 650]
LATE = [780]


# =========================
# RISK SYSTEM
# =========================
def pair_risk(c1, c2, same_location=False, weak=False, strong=False, morph_diff=False):
    if c1 == c2:
        return 999

    if 780 in [c1, c2]:
        base = 0
    elif 480 in [c1, c2]:
        base = 1
    else:
        dist = abs(CHANNELS.index(c1) - CHANNELS.index(c2))
        mapping = {1: 5, 2: 4, 3: 3, 4: 2, 5: 1, 6: 0}
        base = mapping.get(dist, 0)

    if same_location and not morph_diff:
        base += 1
    if weak:
        base += 1
    if strong:
        base -= 1

    return max(0, base)


def spacing_rule_ok(channels):
    ordered = sorted(channels, key=lambda x: CHANNELS.index(x))
    for i in range(len(ordered) - 1):
        if abs(CHANNELS.index(ordered[i + 1]) - CHANNELS.index(ordered[i])) < 2:
            return False
    return True


def spread_penalty(channels):
    ordered = sorted(channels, key=lambda x: CHANNELS.index(x))
    penalty = 0
    for i in range(len(ordered) - 1):
        dist = abs(CHANNELS.index(ordered[i + 1]) - CHANNELS.index(ordered[i]))
        if dist == 2:
            penalty += 4
        elif dist == 3:
            penalty += 1
    return penalty


def late_channel_penalty(channels, n):
    penalty = 0
    if 780 in channels:
        if n <= 5:
            penalty += 12
        elif n == 6:
            penalty += 6
    return penalty


# =========================
# CHECKPOINT HARD RULE
# =========================
def checkpoint_rule_ok(assign_map, checkpoint_pairs):
    """
    HARD CONSTRAINT:
    checkpoint pairs must have at least distance >= 2
    (i.e., must skip at least 1 channel in between)
    """
    for m1, m2 in checkpoint_pairs:
        if m1 in assign_map and m2 in assign_map:
            idx1 = CHANNELS.index(assign_map[m1])
            idx2 = CHANNELS.index(assign_map[m2])
            if abs(idx1 - idx2) < 2:
                return False
    return True


# =========================
# TOTAL RISK
# =========================
def total_risk(df, assign_map, checkpoint_pairs, morph_pairs):
    score = 0

    morph_pairs = set(tuple(sorted(p)) for p in morph_pairs)

    for i in range(len(df)):
        for j in range(i + 1, len(df)):
            a = df.iloc[i]
            b = df.iloc[j]

            m1, m2 = a["marker"], b["marker"]

            if m1 not in assign_map or m2 not in assign_map:
                continue

            same = a["location"] == b["location"]
            weak = "weak" in [a["strength"], b["strength"]]
            strong = "strong" in [a["strength"], b["strength"]]

            morph_diff = tuple(sorted([m1, m2])) in morph_pairs

            score += pair_risk(assign_map[m1], assign_map[m2], same, weak, strong, morph_diff)

    # soft penalty (still kept)
    for m1, m2 in checkpoint_pairs:
        if m1 in assign_map and m2 in assign_map:
            dist = abs(CHANNELS.index(assign_map[m1]) - CHANNELS.index(assign_map[m2]))
            score += max(0, 4 - dist) * 2

    return score


# =========================
# MAIN OPTIMIZER
# =========================
def suggest_panel(df,
                  checkpoint_pairs=None,
                  morph_pairs=None,
                  fixed=None,
                  seg_marker=None):

    checkpoint_pairs = checkpoint_pairs or []
    morph_pairs = morph_pairs or []
    fixed = fixed or {}

    reserved_map = {}
    reserved_channels = set()

    # segmentation marker → 480
    if seg_marker:
        reserved_map[seg_marker] = 480
        reserved_channels.add(480)

    # fixed markers
    for m, c in fixed.items():
        reserved_map[m] = c
        reserved_channels.add(c)

    # remaining markers
    remaining = [m for m in df["marker"] if m not in reserved_map]
    n = len(remaining)

    pool = [c for c in (PREFERRED + INTERMEDIATE + LATE) if c not in reserved_channels]

    best = None
    best_score = None

    for combo in itertools.combinations(pool, n):
        if not spacing_rule_ok(combo):
            continue

        for perm in itertools.permutations(combo):
            assign_map = reserved_map.copy()
            assign_map.update({remaining[i]: perm[i] for i in range(n)})

            # HARD CONSTRAINT
            if not checkpoint_rule_ok(assign_map, checkpoint_pairs):
                continue

            risk = total_risk(df, assign_map, checkpoint_pairs, morph_pairs)
            spread = spread_penalty(list(assign_map.values()))
            late = late_channel_penalty(list(assign_map.values()), len(df))

            score = (late, risk, spread)

            if best_score is None or score < best_score:
                best_score = score
                best = assign_map

    return best, best_score


# =========================
# DEMO RUN
# =========================
if __name__ == "__main__":

    df = pd.DataFrame([
        {"marker": "CD3", "location": "membrane", "strength": "strong"},
        {"marker": "GranB", "location": "membrane", "strength": "weak"},
        {"marker": "CD68", "location": "membrane", "strength": "medium"},
        {"marker": "PanCK", "location": "cytoplasm", "strength": "strong"},
    ])

    checkpoint_pairs = [("CD3", "GranB")]

    result, score = suggest_panel(
        df,
        checkpoint_pairs=checkpoint_pairs,
        morph_pairs=[],
        fixed={},
        seg_marker=None
    )

    print("\nBest Assignment:")
    for k, v in result.items():
        print(f"{k} -> {v}")

    print("\nScore:", score)
